# ─── Domaine (pour HTTPS / Let's Encrypt) ─────────────────────────────────────
DOMAIN=monsite.fr

# ─── Ports ────────────────────────────────────────────────────────────────────
FRONTEND_PORT=3000
USER_SERVICE_PORT=3002
ACCOUNT_SERVICE_PORT=3003
NOTIFICATION_SERVICE_PORT=3001

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=supersecret_jwt_key_for_course

# ─── Base de données (chemins dans les conteneurs Docker) ─────────────────────
USER_DB_PATH=/app/data/users.db
ACCOUNT_DB_PATH=/app/data/accounts.db
NOTIFICATION_DB_PATH=/app/data/notifications.db

# ─── URLs internes Docker (communication inter-services) ─────────────────────
USER_SERVICE_URL=http://user-service:3002
ACCOUNT_SERVICE_URL=http://account-service:3003
NOTIFICATION_SERVICE_URL=http://notification-service:3001
